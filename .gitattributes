# Default: text, normalize line endings to LF
* text=auto eol=lf

# Ensure these are LF even on Windows checkouts
*.rs       text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.md       text eol=lf
*.json     text eol=lf
*.jsonl    text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.toml     text eol=lf
Justfile   text eol=lf
Cargo.toml text eol=lf

# Binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.tar.gz   binary

# Linguist hints (для GitHub language stats)
fixtures/** linguist-vendored
specs/**    linguist-documentation
*.md        linguist-documentation
