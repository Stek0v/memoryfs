{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://memoryfs.dev/schemas/v1/base.schema.json",
  "title": "MemoryFS Base Frontmatter",
  "description": "Общие определения, на которые ссылаются все типизированные схемы фронтматтера v1.",
  "type": "object",
  "$defs": {
    "schema_version": {
      "description": "Имя и версия схемы. Формат `memoryfs/v<major>` либо `memoryfs/v<major>.<minor>`.",
      "type": "string",
      "pattern": "^memoryfs/v[0-9]+(\\.[0-9]+)?$"
    },
    "ulid": {
      "description": "Crockford-Base32 ULID (26 символов).",
      "type": "string",
      "pattern": "^[0123456789ABCDEFGHJKMNPQRSTVWXYZ]{26}$"
    },
    "id_memory": {
      "type": "string",
      "pattern": "^mem_[0123456789ABCDEFGHJKMNPQRSTVWXYZ]{26}$"
    },
    "id_conversation": {
      "type": "string",
      "pattern": "^conv_[0123456789ABCDEFGHJKMNPQRSTVWXYZ]{26}$"
    },
    "id_run": {
      "type": "string",
      "pattern": "^run_[0123456789ABCDEFGHJKMNPQRSTVWXYZ]{26}$"
    },
    "id_entity": {
      "type": "string",
      "pattern": "^ent_[0123456789ABCDEFGHJKMNPQRSTVWXYZ]{26}$"
    },
    "id_decision": {
      "type": "string",
      "pattern": "^dec_[0123456789ABCDEFGHJKMNPQRSTVWXYZ]{26}$"
    },
    "id_proposal": {
      "type": "string",
      "pattern": "^prp_[0123456789ABCDEFGHJKMNPQRSTVWXYZ]{26}$"
    },
    "id_workspace": {
      "type": "string",
      "pattern": "^ws_[0123456789ABCDEFGHJKMNPQRSTVWXYZ]{26}$"
    },
    "id_event": {
      "type": "string",
      "pattern": "^evt_[0123456789ABCDEFGHJKMNPQRSTVWXYZ]{26}$"
    },
    "commit_hash": {
      "description": "Полный sha256 коммита object-store, hex lowercase.",
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "iso8601_utc": {
      "description": "ISO-8601 в UTC с суффиксом Z, миллисекундная точность.",
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,3})?Z$"
    },
    "subject_pattern": {
      "description": "Идентификатор субъекта прав. Поддерживаются префиксы `user:`, `agent:`, `group:`, `role:`, литералы `owner`, `anonymous`, и glob `*` после префикса.",
      "type": "string",
      "pattern": "^(user|agent|group|role):[A-Za-z0-9_\\-\\*]+$|^owner$|^anonymous$"
    },
    "permissions": {
      "description": "ACL для файла. Эффективные права: пересечение с глобальной policy.yaml. Расширение прав за пределы глобальной policy запрещено.",
      "type": "object",
      "additionalProperties": false,
      "required": ["read", "write"],
      "properties": {
        "read": {
          "type": "array",
          "items": { "$ref": "#/$defs/subject_pattern" },
          "minItems": 1,
          "uniqueItems": true
        },
        "write": {
          "type": "array",
          "items": { "$ref": "#/$defs/subject_pattern" },
          "uniqueItems": true
        },
        "review": {
          "description": "Кто имеет право подтверждать sensitive-памяти. Если опущено — берётся из policy.yaml.",
          "type": "array",
          "items": { "$ref": "#/$defs/subject_pattern" },
          "uniqueItems": true
        }
      }
    },
    "provenance": {
      "description": "Происхождение записи. Обязательно для memory/proposal; рекомендуется для всех остальных типов.",
      "type": "object",
      "additionalProperties": false,
      "required": ["source_file", "source_commit", "extracted_at"],
      "properties": {
        "source_file": {
          "description": "Путь внутри workspace. Не должен содержать `..` или абсолютных путей.",
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9_./\\-]+$"
        },
        "source_commit": { "$ref": "#/$defs/commit_hash" },
        "source_span": {
          "description": "Координаты отрывка в исходном файле. Минимум одно из полей обязано присутствовать.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "start_line": { "type": "integer", "minimum": 1 },
            "end_line": { "type": "integer", "minimum": 1 },
            "conv_turn_index": { "type": "integer", "minimum": 0 },
            "heading_path": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 256 },
              "maxItems": 16
            }
          },
          "anyOf": [
            { "required": ["start_line", "end_line"] },
            { "required": ["conv_turn_index"] },
            { "required": ["heading_path"] }
          ]
        },
        "run_id": { "$ref": "#/$defs/id_run" },
        "extractor": {
          "description": "Идентификатор автора-извлекателя в формате `agent:<name>`, `system:<name>` или `user:<id>`.",
          "type": "string",
          "pattern": "^(agent|system|user):[A-Za-z0-9_\\-]+$"
        },
        "extracted_at": { "$ref": "#/$defs/iso8601_utc" },
        "model_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "prompt_hash": {
          "description": "sha256 промпта, который произвёл извлечение.",
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "author": {
      "description": "Кто создал файл. Формат субъекта.",
      "type": "string",
      "pattern": "^(user|agent|system):[A-Za-z0-9_\\-]+$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_\\-]{0,63}$"
      },
      "uniqueItems": true,
      "maxItems": 64
    },
    "scope": {
      "type": "string",
      "enum": ["user", "agent", "session", "project", "org"]
    },
    "sensitivity": {
      "description": "Класс чувствительности. Влияет на политику auto-commit, индексацию и логирование.",
      "type": "string",
      "enum": ["normal", "pii", "secret", "medical", "legal", "financial"],
      "default": "normal"
    },
    "entity_ref": {
      "description": "Ссылка на entity по ULID — никогда по человекочитаемому имени.",
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/id_entity" },
        "role": {
          "description": "Опциональная роль entity в данном контексте (например, `assignee`, `mentioned`).",
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      }
    }
  }
}
