# Copy to .env and adjust paths:
#   cp scripts/.env.example scripts/.env

# Path to Levara server source directory (must contain Dockerfile + go.mod).
# Clone from: git clone https://github.com/Stek0v/Levara
LEVARA_REPO_PATH=/path/to/Levara/Levara

# DeepSeek API key for LLM extraction (optional for dev, required for extraction).
# DEEPSEEK_API_KEY=sk-...
